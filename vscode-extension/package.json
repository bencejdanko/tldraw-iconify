{
  "name": "tldraw-vscode",
  "displayName": "tldraw for VS Code",
  "description": "Edit .tldr files with the full tldraw experience",
  "version": "1.0.0",
  "publisher": "bencejdanko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bencejdanko/tldraw-pwa-app"
  },
  "homepage": "https://tldraw-pwa.pages.dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [],
  "contributes": {
    "customEditors": [
      {
        "viewType": "tldraw.editor",
        "displayName": "tldraw Editor",
        "selector": [
          {
            "filenamePattern": "*.tldr"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run bundle-assets",
    "build": "tsc -b",
    "bundle-assets": "rm -rf dist-app public && cp -r ../dist ./dist-app && cp -r ../public ./public",
    "package": "npx @vscode/vsce package",
    "publish": "npx ovsx publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}

{
  "name": "tldraw-iconify",
  "displayName": "tldraw-iconify",
  "description": "Edit .tldr files with the full tldraw experience",
  "version": "1.0.2",
  "publisher": "bencejdanko",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bencejdanko/tldraw-iconify"
  },
  "homepage": "https://tldraw-iconify.pages.dev",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "icon": "public/pencil.png",
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "contributes": {
    "languages": [
      {
        "id": "tldr",
        "extensions": [
          ".tldr"
        ],
        "aliases": [
          "tldraw"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "public/pencil.png",
          "dark": "public/pencil.png"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "tldraw.editor",
        "displayName": "tldraw Editor",
        "selector": [
          {
            "filenamePattern": "*.tldr"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build && npm run bundle-assets",
    "build": "tsc -b",
    "bundle-assets": "rm -rf dist-app public README.md && cp -r ../dist ./dist-app && cp -r ../public ./public && cp ../README.md ./README.md",
    "package": "npx @vscode/vsce package",
    "publish": "npx ovsx publish"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "typescript": "^5.8.3"
  }
}
